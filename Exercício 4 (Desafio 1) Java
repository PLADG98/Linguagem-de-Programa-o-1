public class Main {
    public static void main(String[] args) {
        int[] A = {3, 5, 6, 8, 10, 12, 14, 16};
        int[] B = new int[8];

        for (int i = 0; i < A.length; i++) {
            B[i] = A[i] * 3;
        }

        System.out.print("Matriz B: ");
        for (int valor : B) {
            System.out.print(valor + " ");
        }
    }
}
