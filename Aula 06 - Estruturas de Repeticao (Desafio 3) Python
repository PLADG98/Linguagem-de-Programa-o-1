soma_notas = 0
quantidade_de_notas = 5

print(f"--- Calculadora de Média ({quantidade_de_notas} notas) ---")

for i in range(1, quantidade_de_notas + 1):
    nota = float(input(f"Digite a nota {i}: "))

    soma_notas += nota 

media = soma_notas / quantidade_de_notas

print("-" * 30)
print(f"A soma das notas é: {soma_notas}")
print(f"A média final do aluno é: {media:.2f}")
