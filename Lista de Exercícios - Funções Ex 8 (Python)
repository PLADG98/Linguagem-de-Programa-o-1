VERSÃO 2
def classificar_triangulo(a, b, c):
    if a == b == c:
        return "Equilátero"
    elif a == b or a == c or b == c:
        return "Isósceles"
    else:
        return "Escaleno"

print("--- Classificador de Triângulos ---")

l1 = float(input("Lado 1: "))
l2 = float(input("Lado 2: "))
l3 = float(input("Lado 3: "))

tipo = classificar_triangulo(l1, l2, l3)

print(f"Com as medidas informadas, o triângulo é {tipo}.")
