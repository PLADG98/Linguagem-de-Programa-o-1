VERSÃO 2
def calcular_area_retangulo(b, h):
    return b * h

print("--- Calculadora de Área: Retângulo (Modular) ---")

base_usuario = float(input("Digite a base do retângulo: "))
altura_usuario = float(input("Digite a altura do retângulo: "))
area_final = calcular_area_retangulo(base_usuario, altura_usuario)

print(f"Resultado: Um retângulo de {base_usuario}x{altura_usuario} possui área de {area_final:.2f}.")
